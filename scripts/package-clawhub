#!/usr/bin/env python3
"""Create deterministic ClawHub skill zip packages."""

from __future__ import annotations

import argparse
import fnmatch
import hashlib
import os
from pathlib import Path
import re
import shutil
import sys
import tempfile
import zipfile


ROOT = Path(__file__).resolve().parents[1]
SKILLS_DIR = ROOT / "skills"
DIST_DIR = ROOT / "dist"
FIXED_ZIP_TIME = (1980, 1, 1, 0, 0, 0)
DEFAULT_EXCLUDES = [
    ".clawhub/",
    ".clawdhub/",
    ".DS_Store",
    "Thumbs.db",
    "*.swp",
    "*.swo",
    "*~",
]


def fail(message: str) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(1)


def parse_frontmatter(skill_md: Path) -> dict[str, str]:
    text = skill_md.read_text(encoding="utf-8")
    match = re.match(r"^---\n(.*?)\n---\n", text, flags=re.S)
    if not match:
        fail(f"{skill_md} is missing YAML frontmatter")

    metadata: dict[str, str] = {}
    for line in match.group(1).splitlines():
        field = re.match(r"^([A-Za-z0-9_-]+):\s*(.*?)\s*$", line)
        if field:
            value = field.group(2).strip()
            metadata[field.group(1)] = value.strip('"').strip("'")

    return metadata


def load_ignore_patterns(skill_dir: Path) -> list[str]:
    patterns = list(DEFAULT_EXCLUDES)
    for ignore_file in [skill_dir / ".clawhubignore", skill_dir / ".gitignore"]:
        if not ignore_file.exists():
            continue
        for raw_line in ignore_file.read_text(encoding="utf-8").splitlines():
            line = raw_line.strip()
            if line and not line.startswith("#"):
                patterns.append(line)
    return patterns


def matches_pattern(path: str, pattern: str) -> bool:
    pattern = pattern.lstrip("/")
    if not pattern:
        return False
    if pattern.endswith("/"):
        prefix = pattern.rstrip("/") + "/"
        return path.startswith(prefix)
    if "/" not in pattern:
        return fnmatch.fnmatch(Path(path).name, pattern) or fnmatch.fnmatch(path, pattern)
    return fnmatch.fnmatch(path, pattern)


def should_ignore(path: str, patterns: list[str]) -> bool:
    return any(matches_pattern(path, pattern) for pattern in patterns)


def package_skill(skill_dir: Path, output: Path | None) -> Path:
    skill_md = skill_dir / "SKILL.md"
    if not skill_md.exists():
        fail(f"{skill_dir} does not contain SKILL.md")

    metadata = parse_frontmatter(skill_md)
    name = metadata.get("name")
    version = metadata.get("version")
    if not name:
        fail(f"{skill_md} frontmatter is missing name")
    if not version:
        fail(f"{skill_md} frontmatter is missing version")

    output_path = output or DIST_DIR / f"{name}-{version}-clawhub.zip"
    output_path.parent.mkdir(parents=True, exist_ok=True)
    patterns = load_ignore_patterns(skill_dir)

    files: list[Path] = []
    for path in sorted(skill_dir.rglob("*")):
        if not path.is_file():
            continue
        rel = path.relative_to(skill_dir).as_posix()
        if should_ignore(rel, patterns):
            continue
        try:
            path.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            fail(f"{rel} is not UTF-8 text; ClawHub skill packages should contain text files only")
        files.append(path)

    if skill_md not in files:
        fail("SKILL.md would be excluded from the package")

    with tempfile.NamedTemporaryFile(prefix=output_path.name, suffix=".tmp", delete=False) as tmp:
        tmp_path = Path(tmp.name)

    try:
        with zipfile.ZipFile(tmp_path, "w", compression=zipfile.ZIP_DEFLATED, compresslevel=9) as archive:
            for path in files:
                rel = path.relative_to(skill_dir).as_posix()
                mode = 0o755 if os.access(path, os.X_OK) else 0o644
                info = zipfile.ZipInfo(rel, FIXED_ZIP_TIME)
                info.compress_type = zipfile.ZIP_DEFLATED
                info.external_attr = mode << 16
                archive.writestr(info, path.read_bytes())
        shutil.move(str(tmp_path), output_path)
    finally:
        if tmp_path.exists():
            tmp_path.unlink()

    digest = hashlib.sha256(output_path.read_bytes()).hexdigest()
    print(f"wrote {output_path.relative_to(ROOT)}")
    print(f"sha256 {digest}")
    return output_path


def resolve_skill(value: str) -> Path:
    path = Path(value)
    if path.exists():
        return path.resolve()
    return SKILLS_DIR / value


def main() -> None:
    parser = argparse.ArgumentParser(description="Create deterministic ClawHub skill zip packages.")
    parser.add_argument("skill", help="Skill slug under ./skills, or path to a skill directory")
    parser.add_argument("-o", "--output", type=Path, help="Output zip path")
    args = parser.parse_args()

    package_skill(resolve_skill(args.skill), args.output.resolve() if args.output else None)


if __name__ == "__main__":
    main()
