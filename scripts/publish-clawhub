#!/usr/bin/env python3
"""Package and publish a skill to ClawHub."""

from __future__ import annotations

import argparse
from pathlib import Path
import re
import shutil
import subprocess
import sys


ROOT = Path(__file__).resolve().parents[1]
SKILLS_DIR = ROOT / "skills"
PACKAGE_SCRIPT = ROOT / "scripts" / "package-clawhub"


def fail(message: str) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(1)


def parse_frontmatter(skill_md: Path) -> dict[str, str]:
    text = skill_md.read_text(encoding="utf-8")
    match = re.match(r"^---\n(.*?)\n---\n", text, flags=re.S)
    if not match:
        fail(f"{skill_md} is missing YAML frontmatter")

    metadata: dict[str, str] = {}
    for line in match.group(1).splitlines():
        field = re.match(r"^([A-Za-z0-9_-]+):\s*(.*?)\s*$", line)
        if field:
            value = field.group(2).strip()
            metadata[field.group(1)] = value.strip('"').strip("'")
    return metadata


def resolve_skill(value: str) -> Path:
    path = Path(value)
    if path.exists():
        return path.resolve()
    return SKILLS_DIR / value


def run(command: list[str], *, dry_run: bool = False) -> subprocess.CompletedProcess[str] | None:
    print("+ " + " ".join(command))
    if dry_run:
        return None
    return subprocess.run(command, cwd=ROOT, text=True, check=True)


def command_help(command: list[str]) -> str:
    result = subprocess.run(
        command,
        cwd=ROOT,
        text=True,
        check=True,
        capture_output=True,
    )
    return result.stdout


def has_uncommitted_changes() -> bool:
    result = subprocess.run(
        ["git", "status", "--short"],
        cwd=ROOT,
        text=True,
        check=True,
        capture_output=True,
    )
    return bool(result.stdout.strip())


def display_name_from_slug(slug: str) -> str:
    acronyms = {"ai", "api", "cd", "ci", "cli", "okrs", "sdk", "ui"}
    words = []
    for part in slug.split("-"):
        words.append(part.upper() if part in acronyms else part.capitalize())
    return " ".join(words)


def package_skill(skill_arg: str, dry_run: bool) -> None:
    run([str(PACKAGE_SCRIPT), skill_arg], dry_run=dry_run)


def publish_prefix(clawhub: str) -> list[str]:
    skill_help = command_help([clawhub, "skill", "--help"])
    if re.search(r"^\s*publish\b", skill_help, flags=re.M):
        return [clawhub, "skill", "publish"]

    root_help = command_help([clawhub, "--help"])
    if re.search(r"^\s*publish\b", root_help, flags=re.M):
        return [clawhub, "publish"]

    fail("this clawhub CLI does not expose a skill publish command. Try updating it with `npm i -g clawhub`.")


def publish(
    skill_dir: Path,
    metadata: dict[str, str],
    changelog: str,
    tags: str,
    display_name: str | None,
    dry_run: bool,
) -> None:
    clawhub = shutil.which("clawhub")
    if clawhub is None:
        fail("clawhub CLI is not installed. Install it with `npm i -g clawhub` and run `clawhub login`.")

    name = metadata.get("name")
    version = metadata.get("version")
    if not name:
        fail("SKILL.md frontmatter is missing name")
    if not version:
        fail("SKILL.md frontmatter is missing version")

    resolved_display_name = display_name or display_name_from_slug(name)
    command = [
        *publish_prefix(clawhub),
        str(skill_dir.relative_to(ROOT)),
        "--slug",
        name,
        "--name",
        resolved_display_name,
        "--version",
        version,
        "--tags",
        tags,
        "--changelog",
        changelog,
    ]
    try:
        run(command, dry_run=dry_run)
    except subprocess.CalledProcessError as error:
        fail(f"clawhub publish failed with exit code {error.returncode}; see the command output above.")


def main() -> None:
    parser = argparse.ArgumentParser(description="Package and publish a skill to ClawHub.")
    parser.add_argument("skill", help="Skill slug under ./skills, or path to a skill directory")
    parser.add_argument("--changelog", required=True, help="ClawHub version changelog")
    parser.add_argument("--name", help="Display name to publish. Defaults to a title-cased skill name.")
    parser.add_argument("--tags", default="latest", help="Comma-separated tags. Defaults to latest.")
    parser.add_argument("--dry-run", action="store_true", help="Print commands without running them")
    args = parser.parse_args()

    skill_dir = resolve_skill(args.skill)
    skill_md = skill_dir / "SKILL.md"
    if not skill_md.exists():
        fail(f"{skill_dir} does not contain SKILL.md")

    metadata = parse_frontmatter(skill_md)

    if has_uncommitted_changes():
        print("warning: working tree has uncommitted changes; publishing will use current files.", file=sys.stderr)

    package_skill(args.skill, args.dry_run)
    publish(skill_dir, metadata, args.changelog, args.tags, args.name, args.dry_run)


if __name__ == "__main__":
    main()
